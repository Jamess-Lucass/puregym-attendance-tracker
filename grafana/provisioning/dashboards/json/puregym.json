{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "title": "PureGym Occupancy",
  "uid": "puregym-occupancy",
  "tags": ["puregym"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "gym",
        "label": "Gym",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(puregym_gym_occupancy, gym_name)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Current occupancy",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 150 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "puregym_gym_occupancy{gym_name=\"$gym\"}",
          "refId": "A",
          "legendFormat": "{{gym_name}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "7-day peak",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["max"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "max_over_time(puregym_gym_occupancy{gym_name=\"$gym\"}[7d])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Scrape health",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "FAILING", "color": "red" },
                "1": { "text": "OK", "color": "green" }
              }
            }
          ]
        }
      },
      "targets": [
        {
          "expr": "puregym_scrape_success{gym_name=\"$gym\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Occupancy over time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "puregym_gym_occupancy{gym_name=\"$gym\"}",
          "refId": "A",
          "legendFormat": "{{gym_name}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "heatmap",
      "title": "Average occupancy by hour of day (last 30 days)",
      "description": "Buckets the last 30 days into hour-of-day columns. Useful for spotting the quietest slot in a typical day.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "options": {
        "calculate": false,
        "color": { "scheme": "Spectral", "mode": "scheme", "reverse": true },
        "yAxis": { "axisPlacement": "hidden" },
        "cellGap": 1,
        "tooltip": { "show": true, "yHistogram": false, "showColorScale": true }
      },
      "targets": [
        {
          "expr": "avg_over_time(puregym_gym_occupancy{gym_name=\"$gym\"}[1h])",
          "refId": "A",
          "format": "time_series",
          "interval": "1h",
          "legendFormat": "{{gym_name}}",
          "range": true
        }
      ]
    }
  ]
}
